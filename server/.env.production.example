# Production Environment Variables
NODE_ENV=production
PORT=5000

# Database
DATABASE_URL=mongodb://localhost:27017/ecommerce

# JWT
JWT_SECRET=replace_with_strong_production_secret

# Client URL / CORS
CLIENT_URL=https://wolfsupplies.co.uk
VITE_API_URL=https://wolfsupplies.co.uk
COOKIE_DOMAIN=.wolfsupplies.co.uk

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=replace_with_email_user
EMAIL_PASSWORD=replace_with_email_app_password

# Cloudinary
CLOUDINARY_NAME=replace_with_cloudinary_name
CLOUDINARY_API_KEY=replace_with_cloudinary_api_key
CLOUDINARY_API_SECRET=replace_with_cloudinary_api_secret

# Stripe
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=replace_with_stripe_publishable_key

# Uploads
UPLOADS_DIR=/app/uploads

# Logging
LOG_LEVEL=info
